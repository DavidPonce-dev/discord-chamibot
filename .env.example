# Discord Bot Token (required)
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID (required for command registration)
# Found in: Developer Portal > Your Application > General Information
CLIENT_ID=your_client_id_here

# Admin Panel Access Token (required)
# Generate with: openssl rand -hex 32
# Access the admin panel at: https://your-server:3002/?token=YOUR_ADMIN_TOKEN
ADMIN_TOKEN=

# YouTube Cookies (optional but recommended)
# Paste Netscape-format cookies here, or place them in /cookies/youtube-cookies.txt
# YOUTUBE_COOKIES=

# Cookie directory (optional, defaults to /cookies in Docker)
# COOKIE_DIR=/cookies

# Cookie Refresher Service URL (for Docker deployments)
# COOKIE_REFRESHER_URL=http://cookie-refresher:3001
