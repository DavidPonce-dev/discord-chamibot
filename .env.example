# Discord Bot Token (required)
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID (required for command registration)
# Found in: Developer Portal > Your Application > General Information
CLIENT_ID=your_client_id_here

# Admin Panel Access Token (required)
# Generate with: openssl rand -hex 32
# Access the admin panel at: https://your-server:3002/?token=YOUR_ADMIN_TOKEN
ADMIN_TOKEN=your_admin_token_here

# Admin Panel Allowed Origins (comma-separated, optional)
# Add your frontend URLs here for CORS
ADMIN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
