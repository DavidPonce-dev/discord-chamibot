# Discord Bot Token (required)
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID (required for command registration)
# Found in: Developer Portal > Your Application > General Information
CLIENT_ID=your_client_id_here

# YouTube Cookies (optional but recommended)
# Paste Netscape-format cookies here, or place them in data/cookies/youtube-cookies.txt
# YOUTUBE_COOKIES=

# Cookie directory (optional, defaults to ./data/cookies/)
# Use this to store cookies in a secure, non-world-readable location
# COOKIE_DIR=./data/cookies

# Cookie Refresher Service URL (for Docker deployments)
# COOKIE_REFRESHER_URL=http://cookie-refresher:3001
